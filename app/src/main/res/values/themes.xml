<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        DayNight theme: automatically switches between light and dark mode
        based on the system setting.
    -->
    <style name="Theme.GuardianTrack" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main theme colors -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Material 3 uses Container colors instead of Variants -->
        <item name="colorPrimaryContainer">@color/purple_700</item>
        <item name="colorSecondaryContainer">@color/teal_700</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>
</resources>
